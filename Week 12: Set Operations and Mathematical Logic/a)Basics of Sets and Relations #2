import java.util.*;

public class Main {
    public static void main(String[] args) {
        Set<Integer> A = new HashSet<>(Arrays.asList(1,2,3,4,5,6));
        Set<Integer> B = new HashSet<>(Arrays.asList(2,3,4,5,6,7,8));

        A.retainAll(B); // finds intersection

        System.out.println(A.size());
    }
}
