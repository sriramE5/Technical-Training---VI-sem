#include <bits/stdc++.h>
using namespace std;

int main() {
	int n, x; 
	cin >> n >> x;
	int a[n];
	
	for(int i = 0; i<n; i++){
	    cin >> a[i];
	}
	
	bool f = false;
	
	for(int j = 0; j<n; j++){
	    if (a[j] == x){
	        f = true;
	        break;
	        
	    }
	    
	}
	if(f){
	    cout << "YES";
	}else{
	    cout << "NO";
	}
	
    
}
